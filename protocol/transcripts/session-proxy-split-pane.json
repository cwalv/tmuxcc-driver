{
  "$schema": "../schemas/session-proxy/server-push.json",
  "description": "Conformance transcript (tc-ozk.4): split-pane verb — a creating verb (tc-ozk.1) that adds a pane to the EXISTING focused window. Returns the new paneId effect id; emits an origin-tagged pane.opened (tc-ozk.2) into w0 and a focus.changed. Exercises the split-pane creating shape (vs open-window's new-window shape).",

  "protocolVersion": 3,

  "initialModel": {
    "session": { "sessionId": "s0", "name": "main" },
    "windows": [
      {
        "windowId": "w0",
        "name": "editor",
        "active": true,
        "paneIds": ["p0"],
        "activePaneId": "p0",
        "synchronizePanes": false,
        "monitorActivity": true,
        "monitorSilence": 0,
        "layout": {
          "cols": 80,
          "rows": 24,
          "root": { "kind": "pane", "paneId": "p0", "rect": { "x": 0, "y": 0, "cols": 80, "rows": 24 } }
        }
      }
    ],
    "panes": [
      { "paneId": "p0", "windowId": "w0", "cols": 80, "rows": 24 }
    ],
    "focus": { "paneId": "p0", "windowId": "w0" },
    "connectionId": "conn1"
  },

  "verbs": {
    "req-101": {
      "response": { "ok": true, "payload": { "paneId": "p1", "windowId": "w0" } },
      "creates": { "newPaneId": "p1", "cols": 40, "rows": 24, "focus": true }
    }
  },

  "transcript": [
    {
      "direction": "session-proxy→client",
      "step": 1,
      "label": "session-proxy advertises capabilities",
      "message": {
        "type": "session-proxy.capabilities",
        "seq": 1,
        "capabilities": { "protocolVersion": 3, "features": ["pane-lifecycle", "layout-updates", "focus-events", "input-forwarding"] }
      }
    },
    {
      "direction": "client→session-proxy",
      "step": 2,
      "label": "client responds with its own capabilities",
      "message": {
        "type": "client.capabilities",
        "seq": 1,
        "capabilities": { "protocolVersion": 3, "features": ["pane-lifecycle", "layout-updates", "focus-events", "input-forwarding"] }
      }
    },
    {
      "direction": "session-proxy→client",
      "step": 3,
      "label": "snapshot (one window, one pane; carries this client's connectionId — tc-ozk.2)",
      "syncPoint": "Baseline established; deltas apply on top.",
      "message": {
        "type": "snapshot",
        "seq": 2,
        "session": { "sessionId": "s0", "name": "main" },
        "windows": [
          {
            "windowId": "w0",
            "name": "editor",
            "active": true,
            "synchronizePanes": false,
            "monitorActivity": true,
            "monitorSilence": 0,
            "layout": {
              "cols": 80,
              "rows": 24,
              "root": { "kind": "pane", "paneId": "p0", "rect": { "x": 0, "y": 0, "cols": 80, "rows": 24 } }
            }
          }
        ],
        "panes": [ { "paneId": "p0", "windowId": "w0", "cols": 80, "rows": 24 } ],
        "focus": { "paneId": "p0", "windowId": "w0" },
        "connectionId": "conn1"
      }
    },
    {
      "direction": "client→session-proxy",
      "step": 4,
      "label": "client splits pane p0 horizontally (split-pane verb, tc-ozk.1)",
      "message": {
        "type": "command.request",
        "seq": 3,
        "correlationId": "req-101",
        "command": { "kind": "split-pane", "paneId": "p0", "direction": "horizontal" }
      }
    },
    {
      "direction": "session-proxy→client",
      "step": 5,
      "label": "session-proxy returns the split's effect ids (tc-ozk.1): the new paneId p1 (in window w0)",
      "message": {
        "type": "command.response",
        "seq": 3,
        "correlationId": "req-101",
        "result": { "ok": true, "payload": { "paneId": "p1", "windowId": "w0" } }
      }
    },
    {
      "direction": "session-proxy→client",
      "step": 6,
      "label": "pane.opened for the split's new pane — origin-tagged (tc-ozk.2): caused by req-101 from conn1",
      "message": {
        "type": "pane.opened",
        "seq": 4,
        "paneId": "p1",
        "windowId": "w0",
        "cols": 40,
        "rows": 24,
        "active": true,
        "origin": { "connectionId": "conn1", "requestId": "req-101" }
      }
    },
    {
      "direction": "session-proxy→client",
      "step": 7,
      "label": "focus.changed to the new pane p1",
      "message": { "type": "focus.changed", "seq": 5, "paneId": "p1", "windowId": "w0" }
    }
  ]
}
