{
  "extends": "../../../projects/tmuxcc/tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src"],
  // Exclude the full-stack e2e smoke test: it imports from @tmuxcc/client
  // (a sibling workspace) via relative src paths outside rootDir, which tsc
  // rejects but tsx handles correctly at runtime.  This matches the pattern
  // used by tmuxcc-vscode's tsconfig for daemon-transport.test.ts.
  "exclude": ["src/runtime/e2e-smoke.test.ts"]
}
