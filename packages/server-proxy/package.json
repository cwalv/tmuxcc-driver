{
  "name": "@tmuxcc/server-proxy",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./src/*": "./src/*"
  },
  "main": "./dist/index.js",
  "scripts": {
    "preinstall": "node ../../scripts/npm-root-guard.mjs",
    "prebuild": "node ../../scripts/npm-root-guard.mjs",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test --test-timeout=60000 \"src/**/*.test.ts\"",
    "lint:boundaries": "depcruise src/ --config .dependency-cruiser.cjs --output-type err",
    "lint:boundaries:verify": "bash scripts/verify-boundary-lint.sh",
    "ci": "npm run build && npm run typecheck && npm run test && npm run lint:boundaries",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@tmuxcc/session-proxy": "*",
    "node-pty": "^1.1.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "dependency-cruiser": "^17.4.3",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
