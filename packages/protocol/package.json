{
  "name": "@tmuxcc/protocol",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./src/*": "./src/*"
  },
  "main": "./dist/index.js",
  "scripts": {
    "preinstall": "node ../../scripts/npm-root-guard.mjs",
    "prebuild": "node ../../scripts/npm-root-guard.mjs",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test --test-timeout=30000 \"src/**/*.test.ts\"",
    "ci": "npm run build && npm run typecheck && npm run test",
    "format": "prettier --write src"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "ajv": "^8.17.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
