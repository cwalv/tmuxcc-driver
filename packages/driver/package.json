{
  "name": "@tmuxcc/driver",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "default": "./dist/testing.js"
    },
    "./src/*": "./src/*"
  },
  "main": "./dist/index.js",
  "scripts": {
    "preinstall": "node ../../scripts/npm-root-guard.mjs",
    "prebuild": "node ../../scripts/npm-root-guard.mjs",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "npm run test:unit && npm run test:real-tmux",
    "test:unit": "node --import tsx --test --test-timeout=30000 \"src/**/!(e2e-smoke|resilience|topology-canary|break-pane-rehome|break-pane-noop|flow-load|flow-abrupt-death|flow-zero-client|resize-roundtrip|integration|tmux-host|test-tmux-cleanup|bootstrap-requery-stall|size-ownership.e2e|collapsed-process-lifecycle.e2e|apply-at-create|apply-to-live|freeze-roundtrip|reply-row-tmux).test.ts\"",
    "test:real-tmux": "node --import tsx --test --test-timeout=30000 --test-concurrency=1 \"src/runtime/e2e-smoke.test.ts\" \"src/runtime/resilience.test.ts\" \"src/runtime/topology-canary.test.ts\" \"src/runtime/break-pane-rehome.test.ts\" \"src/runtime/break-pane-noop.test.ts\" \"src/runtime/flow-load.test.ts\" \"src/runtime/flow-abrupt-death.test.ts\" \"src/runtime/flow-zero-client.test.ts\" \"src/runtime/resize-roundtrip.test.ts\" \"src/runtime/integration.test.ts\" \"src/runtime/size-ownership.e2e.test.ts\" \"src/runtime/tmux-host.test.ts\" \"src/runtime/test-tmux-cleanup.test.ts\" \"src/runtime/bootstrap-requery-stall.test.ts\" \"src/apply-at-create.test.ts\" \"src/apply-to-live.test.ts\" \"src/freeze-roundtrip.test.ts\" \"src/state/reply-row-tmux.test.ts\"",
    "test:soak": "bash scripts/soak-real-tmux.sh",
    "lint:boundaries": "depcruise src/parser/ src/runtime/ --config .dependency-cruiser.cjs --ts-pre-compilation-deps --output-type err",
    "lint:boundaries:verify": "bash scripts/verify-boundary-lint.sh",
    "ci": "npm run build && npm run typecheck && npm run test && npm run lint:boundaries",
    "soak": "npm run build && bash scripts/soak-real-tmux.sh",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@tmuxcc/protocol": "*",
    "node-pty": "^1.1.0",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "dependency-cruiser": "^17.4.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
